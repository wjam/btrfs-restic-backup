[Unit]
Description=Use Restic to backup a BTRFS subvolume
# TODO want network
# TODO want disk

[Service]
Type=oneshot

# Allow the script to remount things as needed
PrivateMounts=true

Environment="SNAPSHOT_NAME=@%N"

ExecStartPre=/usr/local/bin/btrfs-restic-create-snapshot.sh
ExecStart=/usr/local/bin/btrfs-restic-backup.sh
ExecStartPost=/usr/bin/echo start-post
ExecStopPost=/usr/local/bin/btrfs-restic-delete-snapshot.sh
